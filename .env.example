# ──────────────────────────────────────────────────────────────────────────────
# LikeVercel-Docker Environment Configuration Example
# Copy this file to .env and update the values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
# The public URL where the application will be accessible
FRONTEND_URL=http://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────
# For Docker: file:/app/backend/data/db.sqlite
# For Local:  file:./data/db.sqlite
DATABASE_URL=file:/app/backend/data/db.sqlite

# ── Security & Auth ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_at_least_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_here

# Token Expiration
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Encryption ────────────────────────────────────────────────────────────────
# MUST be a 64-character hex string (32 bytes)
# Used for encrypting sensitive VPS credentials and SSH keys.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Note: These are baked into the frontend build. 
# In the Docker production build, the frontend is served by the backend.
VITE_API_URL=http://localhost:3001/api
