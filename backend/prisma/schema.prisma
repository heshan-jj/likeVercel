generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String         @id @default(cuid())
  hashedPin           String
  onboardingCompleted Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  refreshTokens       RefreshToken[]
  sshKeys             SshKey[]
  vpsProfiles         VpsProfile[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model SshKey {
  id                  String    @id @default(cuid())
  userId              String
  label               String
  publicKey           String
  fingerprint         String
  encryptedPrivateKey String
  iv                  String
  authTag             String
  createdAt           DateTime  @default(now())
  lastUsedAt          DateTime?
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VpsProfile {
  id                   String       @id @default(cuid())
  userId               String
  name                 String
  host                 String
  port                 Int          @default(22)
  username             String
  authType             String       @default("password")
  encryptedCredentials String
  iv                   String
  authTag              String
  lastConnectedAt      DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  region               String?
  deployments          Deployment[]
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Deployment {
  id          String     @id @default(cuid())
  vpsId       String
  projectPath String
  processName String
  port        Int?
  status      String     @default("stopped")
  startedAt   DateTime?
  stoppedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  vps         VpsProfile @relation(fields: [vpsId], references: [id], onDelete: Cascade)

  @@index([vpsId])
}
